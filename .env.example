# ── OpenAI / OpenRouter ─────────────────────────────────────
# ⚠️  Ne jamais committer ce fichier (.env est dans .gitignore)
#
# OpenAI direct:
# OPENAI_API_KEY=sk-...
#
# OpenRouter:
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Modèle (vision + texte requis)
#   OpenAI direct    → gpt-4.1
#   OpenRouter       → openai/gpt-4.1
OPENAI_MODEL=openai/gpt-4.1

# ── Netlify (rempli automatiquement en déploiement) ──────────
# NETLIFY_BLOBS_CONTEXT=...  (auto)
