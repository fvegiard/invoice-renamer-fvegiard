# ── OpenAI ──────────────────────────────────────────────────
# Clé API → https://platform.openai.com/api-keys
# ⚠️  Ne jamais committer ce fichier (.env est dans .gitignore)
OPENAI_API_KEY=sk-...

# Modèle (vision + texte requis)
#   gpt-4.1        → recommandé
#   gpt-4.1-mini   → plus rapide, moins cher
#   gpt-5.4        → le meilleur, plus cher
OPENAI_MODEL=gpt-4.1

# ── Netlify (rempli automatiquement en déploiement) ──────────
# NETLIFY_BLOBS_CONTEXT=...  (auto)
